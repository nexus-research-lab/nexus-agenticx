#!/usr/bin/env bash
# AgenticX · pre-commit hook
#
# 扫描 staged diff + 新增文件路径，命中敏感 pattern 则阻止提交。
# 支持两个 pattern 文件：
#   - .githooks/patterns.txt         通用模式（随仓）
#   - .githooks/patterns.local.txt   个人模式（gitignore）
#
# 绕过（紧急场景）：git commit --no-verify

set -eu

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PATTERNS_GLOBAL=".githooks/patterns.txt"
PATTERNS_LOCAL=".githooks/patterns.local.txt"

# ---- 校验前置 ----
if [ ! -f "$PATTERNS_GLOBAL" ]; then
  echo -e "${YELLOW}[pre-commit] 未找到 $PATTERNS_GLOBAL，跳过扫描。${NC}"
  exit 0
fi

# ---- 收集 staged 内容 ----
# 只扫文本，二进制自动跳过；--diff-filter=ACMR 覆盖增改改名复制
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR || true)"
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# 只扫 staged 增量（减号行不扫，只看 + 新增行）
# 排除 pattern 定义文件：否则 RE: 行会与「私钥/Token 等」规则自命中
STAGED_DIFF="$(
  git diff --cached --diff-filter=ACMR -U0 -- . \
    ':(exclude).githooks/patterns.txt' \
    ':(exclude).githooks/patterns.local.txt' 2>/dev/null \
  | grep -E '^\+' | grep -Ev '^\+\+\+' || true
)"

# ---- 读取 pattern ----
parse_patterns() {
  local file="$1"
  [ -f "$file" ] || return 0
  # 去掉空行和注释
  grep -v '^\s*#' "$file" | grep -v '^\s*$' || true
}

PATTERN_LINES="$(parse_patterns "$PATTERNS_GLOBAL")"
if [ -f "$PATTERNS_LOCAL" ]; then
  PATTERN_LINES="$PATTERN_LINES"$'\n'"$(parse_patterns "$PATTERNS_LOCAL")"
fi

if [ -z "$PATTERN_LINES" ]; then
  exit 0
fi

# ---- 扫描 ----
HITS=0
HIT_DETAILS=""

while IFS=$'\t' read -r raw_pattern label; do
  [ -z "$raw_pattern" ] && continue
  label="${label:-match}"

  # 前缀区分正则 / 字面
  case "$raw_pattern" in
    RE:*)
      pat="${raw_pattern#RE:}"
      flag="-E"
      ;;
    F:*)
      pat="${raw_pattern#F:}"
      flag="-F"
      ;;
    *)
      pat="$raw_pattern"
      flag="-F"  # 默认字面量，最保守
      ;;
  esac

  # 扫 staged diff 内容（用 -e 显式指定 pattern，避免以 - 开头的 pattern 被当 flag）
  if [ -n "$STAGED_DIFF" ]; then
    match="$(printf '%s' "$STAGED_DIFF" | grep $flag -e "$pat" 2>/dev/null || true)"
    if [ -n "$match" ]; then
      HITS=$((HITS + 1))
      HIT_DETAILS="${HIT_DETAILS}
  [DIFF] ${label}:
$(printf '%s' "$match" | head -3 | sed 's/^/    /')"
    fi
  fi

  # 扫新增文件路径本身
  path_match="$(printf '%s\n' "$STAGED_FILES" | grep $flag -e "$pat" 2>/dev/null || true)"
  if [ -n "$path_match" ]; then
    HITS=$((HITS + 1))
    HIT_DETAILS="${HIT_DETAILS}
  [PATH] ${label}:
$(printf '%s' "$path_match" | sed 's/^/    /')"
  fi
done <<< "$PATTERN_LINES"

# ---- 判定 ----
if [ "$HITS" -gt 0 ]; then
  echo -e "${RED}╔════════════════════════════════════════════════════════════════╗${NC}"
  echo -e "${RED}║  🚨 pre-commit: 检测到 $HITS 处敏感内容，提交已阻止                  ║${NC}"
  echo -e "${RED}╚════════════════════════════════════════════════════════════════╝${NC}"
  echo "$HIT_DETAILS"
  echo ""
  echo -e "${YELLOW}处理建议：${NC}"
  echo "  1. 确认是否误引入敏感信息 → 修改后重新 add + commit"
  echo "  2. 若确实是合法引用（如本脚本本身含示例） → git commit --no-verify"
  echo "  3. 已泄露的凭据要立刻轮换！"
  exit 1
fi

echo -e "${GREEN}✓ pre-commit: 无敏感内容命中${NC}"
exit 0
