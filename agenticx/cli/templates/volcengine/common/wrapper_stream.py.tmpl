#!/usr/bin/env python3
'''AgentKit Streaming Wrapper for AgenticX Agent.'''

import os
import json
import logging

from {{agent_module}} import {{agent_var}}

from agenticx.deploy.components.volcengine.wrapper import AgenticXAgentWrapper
from agentkit.apps import AgentkitSimpleApp

logger = logging.getLogger(__name__)
logger.setLevel(logging.INFO)

_ark_llm = None
if os.getenv("MODEL_AGENT_NAME"):
    try:
        from agenticx.llms import ArkLLMProvider
        _ark_llm = ArkLLMProvider(
            endpoint_id=os.getenv("MODEL_AGENT_NAME"),
            api_key=os.getenv("MODEL_AGENT_API_KEY"),
        )
        if not getattr({{agent_var}}, "llm", None):
            {{agent_var}}.llm = _ark_llm
    except Exception as e:
        logger.warning("Failed to initialize ArkLLMProvider: %s", e)

app = AgentkitSimpleApp()
wrapper = AgenticXAgentWrapper(agent={{agent_var}}, llm_provider=_ark_llm)


@app.entrypoint
async def run(payload: dict, headers: dict):
    try:
        async for event in wrapper.handle_invoke_stream(payload, headers):
            yield event
    except Exception as e:
        logger.exception("Streaming failed: %s", e)
        yield json.dumps({"type": "error", "content": str(e)}, ensure_ascii=False)


@app.ping
def ping() -> str:
    return wrapper.ping()


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=8000)
